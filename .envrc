use flake
# Prefer venv Python for HERMES_REAL_BIN (scripts/hermes runs `python -m hermes_cli.main`).
# Do NOT run `command -v hermes` before PATH_add — that grabs a global install.
if [[ -x "${PWD}/venv/bin/python" ]]; then
  export HERMES_REAL_BIN="${PWD}/venv/bin/python"
elif [[ -x "${PWD}/venv/bin/hermes" ]]; then
  export HERMES_REAL_BIN="${PWD}/venv/bin/hermes"
else
  export HERMES_REAL_BIN="$(command -v hermes)"
fi
PATH_add scripts
# Short droplet commands (on PATH while this repo is loaded): droplet, droplet-run
#   droplet          → remote Hermes (VPS venv: ./venv/bin/python -m hermes_cli.main …)
#   droplet-run '…'  → remote shell as SSH_USER, no sudo to hermesuser (maintenance)
