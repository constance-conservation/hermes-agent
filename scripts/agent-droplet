#!/usr/bin/env bash
# Backend for workstation `hermes … droplet` (see scripts/hermes shim + Step 15 in
# policies/core/unified-deployment-and-security.md). Runs the same CLI on the VPS (venv + HERMES_HOME). All args forwarded.
# Requires ~/.env/.env with SSH_* (host, port, user). SSH key passphrase is typed interactively
# (env-file SSH_PASSPHRASE / HERMES_DROPLET_ALLOW_ENV_PASSPHRASE is ignored for this entrypoint).
# Remote command uses sudo -u <runtime> by default (sudo -k first). Set AGENT_DROPLET_REQUIRE_SUDO=0
# to run as SSH_USER without sudo (e.g. headless maintenance). See scripts/ssh_droplet.sh header.
# Optional env: AGENT_DROPLET_RUNTIME_USER, AGENT_DROPLET_RUNTIME_HOME, AGENT_DROPLET_REPO,
# AGENT_DROPLET_PROFILE (default chief-orchestrator — passed as -p so argv wins over active_profile)
# HERMES_DROPLET_INTERACTIVE=1 lets ssh_droplet pass its TTY check when stdin is not a TTY (IDE).
# Defaults: runtime user hermesuser, HERMES_HOME …/profiles/chief-orchestrator, repo ~/hermes-agent.
# One-time VPS setup: sudo bash scripts/droplet_bootstrap_hermesuser.sh
#
# env -u: a parent-exported HERMES_DROPLET_ALLOW_ENV_PASSPHRASE must not re-enable file passphrase here;
# ssh_droplet still reads the file, but HERMES_DROPLET_WORKSTATION_CLI=1 disables file-based unlock.
# For headless automation, call scripts/ssh_droplet.sh directly (not via this script).
set -euo pipefail
ROOT="$(cd "$(dirname "$0")" && pwd)"
REPO="$(cd "$ROOT/.." && pwd)"
RUNTIME_USER="${AGENT_DROPLET_RUNTIME_USER:-hermesuser}"
HH=$(printf '%q' "${AGENT_DROPLET_RUNTIME_HOME:-/home/hermesuser/.hermes/profiles/chief-orchestrator}")
REPO_Q=$(printf '%q' "${AGENT_DROPLET_REPO:-/home/hermesuser/hermes-agent}")
PROF_Q=$(printf '%q' "${AGENT_DROPLET_PROFILE:-chief-orchestrator}")
cmd="export HERMES_HOME=${HH}; cd ${REPO_Q} && if [[ ! -x ./venv/bin/python ]]; then echo 'agent-droplet: missing ./venv/bin/python. On the droplet: sudo bash scripts/droplet_bootstrap_hermesuser.sh' >&2; exit 127; fi && exec ./venv/bin/python -m hermes_cli.main -p ${PROF_Q}"
for a in "$@"; do
  cmd+=" $(printf '%q' "$a")"
done
export HERMES_DROPLET_INTERACTIVE=1
export HERMES_DROPLET_WORKSTATION_CLI=1
export HERMES_DROPLET_REQUIRE_SUDO="${AGENT_DROPLET_REQUIRE_SUDO:-${HERMES_DROPLET_REQUIRE_SUDO:-1}}"
exec env -u HERMES_DROPLET_ALLOW_ENV_PASSPHRASE bash "$REPO/scripts/ssh_droplet.sh" --sudo-user "$RUNTIME_USER" "$cmd"
