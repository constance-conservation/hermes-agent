#!/usr/bin/env bash
# Backend for workstation `hermes … droplet` (see scripts/hermes shim + Step 15 in
# policies/core/unified-deployment-and-security.md). Runs the same CLI on the VPS (venv + HERMES_HOME). All args forwarded.
# Requires ~/.env/.env with SSH_* (host, port, user). SSH key passphrase is typed interactively
# (env-file SSH_PASSPHRASE / HERMES_DROPLET_ALLOW_ENV_PASSPHRASE is ignored for this entrypoint).
# If SSH_USER ≠ runtime user, remote sudo prompts for your sudo password (no SSH_SUDO_PASSWORD pipe).
# Optional env: AGENT_DROPLET_RUNTIME_USER, AGENT_DROPLET_RUNTIME_HOME, AGENT_DROPLET_REPO
# HERMES_DROPLET_INTERACTIVE=1 lets ssh_droplet pass its TTY check when stdin is not a TTY (IDE).
# Default runtime user and paths match a typical DO droplet (`hermesadmin` + chief-orchestrator profile).
#
# env -u: a parent-exported HERMES_DROPLET_ALLOW_ENV_PASSPHRASE must not re-enable file passphrase here;
# ssh_droplet still reads the file, but HERMES_DROPLET_WORKSTATION_CLI=1 disables file-based unlock.
# For headless automation, call scripts/ssh_droplet.sh directly (not via this script).
set -euo pipefail
ROOT="$(cd "$(dirname "$0")" && pwd)"
REPO="$(cd "$ROOT/.." && pwd)"
RUNTIME_USER="${AGENT_DROPLET_RUNTIME_USER:-hermesadmin}"
HH=$(printf '%q' "${AGENT_DROPLET_RUNTIME_HOME:-/home/hermesadmin/.hermes/profiles/chief-orchestrator}")
REPO_Q=$(printf '%q' "${AGENT_DROPLET_REPO:-/home/hermesadmin/hermes-agent}")
cmd="export HERMES_HOME=${HH}; cd ${REPO_Q} && if [[ ! -x ./venv/bin/python ]]; then echo 'agent-droplet: missing ./venv/bin/python. On the droplet: python3 -m venv venv && ./venv/bin/pip install -e .' >&2; exit 127; fi && exec ./venv/bin/python -m hermes_cli.main"
for a in "$@"; do
  cmd+=" $(printf '%q' "$a")"
done
export HERMES_DROPLET_INTERACTIVE=1
export HERMES_DROPLET_WORKSTATION_CLI=1
exec env -u HERMES_DROPLET_ALLOW_ENV_PASSPHRASE bash "$REPO/scripts/ssh_droplet.sh" --sudo-user "$RUNTIME_USER" "$cmd"
