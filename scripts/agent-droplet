#!/usr/bin/env bash
# Run the same CLI entrypoint as on the VPS (venv + HERMES_HOME on server). All args forwarded.
# Requires ~/.env/.env with SSH_* and SSH_SUDO_PASSWORD (see scripts/ssh_droplet.sh).
# Optional env: AGENT_DROPLET_RUNTIME_USER, AGENT_DROPLET_RUNTIME_HOME, AGENT_DROPLET_REPO
set -euo pipefail
ROOT="$(cd "$(dirname "$0")" && pwd)"
REPO="$(cd "$ROOT/.." && pwd)"
RUNTIME_USER="${AGENT_DROPLET_RUNTIME_USER:-hermesuser}"
HH=$(printf '%q' "${AGENT_DROPLET_RUNTIME_HOME:-/home/hermesuser/.hermes}")
REPO_Q=$(printf '%q' "${AGENT_DROPLET_REPO:-/home/hermesuser/hermes-agent}")
cmd="export HERMES_HOME=${HH}; cd ${REPO_Q} && exec ./venv/bin/python -m hermes_cli.main"
for a in "$@"; do
  cmd+=" $(printf '%q' "$a")"
done
exec bash "$REPO/scripts/ssh_droplet.sh" --sudo-user "$RUNTIME_USER" "$cmd"
