#!/usr/bin/env bash
# Short entry: remote Hermes on the VPS (venv + HERMES_HOME via agent-droplet).
# Same as: hermes … droplet / scripts/agent-droplet
#
# With direnv, `PATH_add scripts` puts this on PATH — run: droplet   or   droplet doctor
#
# Remote sudo: set SSH_SUDO_PASSWORD in ~/.env/.env (same file as SSH_*) for non-interactive
# sudo -u hermesuser; otherwise you type sudo on the remote TTY.
set -euo pipefail
_ROOT="$(cd "$(dirname "$0")" && pwd)"
exec "$_ROOT/agent-droplet" "$@"
