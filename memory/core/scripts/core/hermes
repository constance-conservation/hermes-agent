#!/usr/bin/env bash
# If the last argument is "droplet", run the same CLI on the VPS (see scripts/core/agent-droplet).
# Otherwise run the repo venv's `hermes` when present (see .envrc); else HERMES_REAL_BIN.
set -euo pipefail
_root="$(cd "$(dirname "$0")" && pwd)"
_repo="$(cd "$_root/../.." && pwd)"
_venv_hermes="$_repo/venv/bin/hermes"
_venv_py="$_repo/venv/bin/python"
_last=
for _last in "$@"; do :; done
if [[ $# -ge 1 && "$_last" == "droplet" ]]; then
  if [[ $# -eq 1 ]]; then
    exec "$_root/agent-droplet"
  fi
  set -- "${@:1:$(($# - 1))}"
  exec "$_root/agent-droplet" "$@"
fi
# Prefer venv python -m hermes_cli.main: venv/bin/hermes may have a stale shebang if the repo moved.
if [[ -x "$_venv_py" ]]; then
  exec "$_venv_py" -m hermes_cli.main "$@"
fi
# In a full checkout, require the repo venv so PATH order cannot silently use a global install.
if [[ -f "$_repo/pyproject.toml" ]]; then
  echo "hermes: this repo expects a venv at ${_venv_py} (run: cd ${_repo} && python3 -m venv venv && ./venv/bin/pip install -e .)" >&2
  exit 127
fi
if [[ -x "$_venv_hermes" ]]; then
  exec "$_venv_hermes" "$@"
fi
if [[ -n "${HERMES_REAL_BIN:-}" && "${HERMES_REAL_BIN}" != "$_root/hermes" ]]; then
  exec "${HERMES_REAL_BIN}" "$@"
fi
echo "hermes: no venv at ${_venv_hermes} or ${_venv_py}; install the repo venv (pip install -e .) or set HERMES_REAL_BIN." >&2
exit 127
