#!/usr/bin/env bash
# Interactive SSH to the Mac mini as MACMINI_SSH_USER (venv shell on the remote checkout).
# Requires HERMES_AGENT_REPO and scripts/core/ssh_operator.sh (see hermes-env.sh).
#
# Local workstation sudo gate lives in scripts/shell/hermes-env.sh (operator function), not here —
# this file is also synced to the mini and must not run sudo on the server.
set -euo pipefail
_REPO="${HERMES_AGENT_REPO:?set HERMES_AGENT_REPO}"
exec bash "${_REPO}/scripts/core/ssh_operator.sh" "$@"
